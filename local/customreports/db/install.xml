<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/customreports/db" VERSION="20240101" COMMENT="XMLDB file for local_customreports plugin"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_customreports_saved" COMMENT="Saved custom reports configurations">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" COMMENT="Report name"/>
        <FIELD NAME="description" TYPE="text" NOTNULL="false" COMMENT="Report description"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="User who created the report"/>
        <FIELD NAME="config" TYPE="text" NOTNULL="true" COMMENT="JSON configuration"/>
        <FIELD NAME="visibility" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" COMMENT="0=private, 1=role, 2=public"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
    </TABLE>
    <TABLE NAME="local_customreports_scheduled" COMMENT="Scheduled report deliveries">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="reportid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Reference to saved report"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="User who scheduled the report"/>
        <FIELD NAME="frequency" TYPE="char" LENGTH="20" NOTNULL="true" COMMENT="daily, weekly, monthly"/>
        <FIELD NAME="schedule_time" TYPE="char" LENGTH="10" NOTNULL="false" COMMENT="HH:MM"/>
        <FIELD NAME="schedule_day" TYPE="int" LENGTH="2" NOTNULL="false" COMMENT="1-7 for weekly, 1-31 for monthly"/>
        <FIELD NAME="lastsent" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="enabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="reportid" TYPE="foreign" FIELDS="reportid" REFTABLE="local_customreports_saved" REFFIELDS="id"/>
        <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
    </TABLE>
    <TABLE NAME="local_customreports_cache" COMMENT="Cache for report data">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="cachekey" TYPE="char" LENGTH="255" NOTNULL="true" COMMENT="MD5 hash of query"/>
        <FIELD NAME="reporttype" TYPE="char" LENGTH="50" NOTNULL="true"/>
        <FIELD NAME="data" TYPE="text" NOTNULL="true" COMMENT="JSON data"/>
        <FIELD NAME="expires" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="cachekey" UNIQUE="true" FIELDS="cachekey"/>
        <INDEX NAME="expires" UNIQUE="false" FIELDS="expires"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
