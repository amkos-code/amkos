{{!
    Custom Reports Dashboard Template
    
    @template     local_customreports/dashboard
    @package      local_customreports
    
    Copyright: 2024
    License: GPL-3.0
}}
<div class="local-customreports-dashboard" data-refresh-interval="{{refreshinterval}}">
    {{! Header with actions }}
    <div class="dashboard-header mb-4">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h2 class="mb-0">
                    <i class="fa fa-chart-line text-primary"></i>
                    {{#str}} dashboard, local_customreports {{/str}}
                </h2>
                <p class="text-muted mt-1">{{#str}} dashboarddesc, local_customreports {{/str}}</p>
            </div>
            <div class="col-md-4 text-md-end">
                <button class="btn btn-primary" data-action="refresh-dashboard">
                    <i class="fa fa-sync"></i>
                    {{#str}} refresh, local_customreports {{/str}}
                </button>
                <button class="btn btn-outline-secondary ms-2" data-action="export-dashboard">
                    <i class="fa fa-download"></i>
                    {{#str}} export, local_customreports {{/str}}
                </button>
                <button class="btn btn-outline-secondary ms-2" data-action="configure-widgets">
                    <i class="fa fa-cog"></i>
                </button>
            </div>
        </div>
    </div>

    {{! Filters Bar }}
    <div class="dashboard-filters card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label for="filter-cohort" class="form-label">{{#str}} cohort, local_customreports {{/str}}</label>
                    <select id="filter-cohort" class="form-select" data-filter="cohort">
                        <option value="">{{#str}} all, local_customreports {{/str}}</option>
                        {{#cohorts}}
                        <option value="{{id}}">{{name}}</option>
                        {{/cohorts}}
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="filter-course" class="form-label">{{#str}} course, local_customreports {{/str}}</label>
                    <select id="filter-course" class="form-select" data-filter="course">
                        <option value="">{{#str}} all, local_customreports {{/str}}</option>
                        {{#courses}}
                        <option value="{{id}}">{{fullname}}</option>
                        {{/courses}}
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="filter-datefrom" class="form-label">{{#str}} datefrom, local_customreports {{/str}}</label>
                    <input type="date" id="filter-datefrom" class="form-control" data-filter="datefrom">
                </div>
                <div class="col-md-3">
                    <label for="filter-dateto" class="form-label">{{#str}} dateto, local_customreports {{/str}}</label>
                    <input type="date" id="filter-dateto" class="form-control" data-filter="dateto">
                </div>
            </div>
        </div>
    </div>

    {{! Widgets Grid }}
    <div class="dashboard-grid row g-4">
        {{! Widget 1: Site Overview }}
        <div class="col-12 col-md-6 col-lg-3 widget-container" data-widget-id="site-overview" data-loaded="false">
            <div class="report-widget card h-100 shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center bg-white">
                    <h5 class="mb-0 fs-6">
                        <i class="fa fa-globe text-primary"></i>
                        {{#str}} siteoverview, local_customreports {{/str}}
                    </h5>
                    <div class="widget-actions">
                        <button class="btn btn-sm btn-link p-0" data-action="refresh-widget" title="{{#str}} refresh, local_customreports {{/str}}">
                            <i class="fa fa-sync"></i>
                        </button>
                    </div>
                </div>
                <div class="card-body p-3">
                    <div class="overview-stats">
                        <div class="stat-item mb-3">
                            <div class="d-flex align-items-center">
                                <div class="stat-icon bg-primary bg-opacity-10 rounded-circle p-2 me-3">
                                    <i class="fa fa-users text-primary"></i>
                                </div>
                                <div>
                                    <div class="stat-value fw-bold">{{totalusers}}</div>
                                    <div class="stat-label text-muted small">{{#str}} totalusers, local_customreports {{/str}}</div>
                                </div>
                                <div class="ms-auto stat-change {{#usergrowth}}text-success{{/usergrowth}}{{^usergrowth}}text-danger{{/usergrowth}}">
                                    <small>{{usergrowth}}%</small>
                                </div>
                            </div>
                        </div>
                        <div class="stat-item mb-3">
                            <div class="d-flex align-items-center">
                                <div class="stat-icon bg-success bg-opacity-10 rounded-circle p-2 me-3">
                                    <i class="fa fa-user-check text-success"></i>
                                </div>
                                <div>
                                    <div class="stat-value fw-bold">{{activetoday}}</div>
                                    <div class="stat-label text-muted small">{{#str}} activetoday, local_customreports {{/str}}</div>
                                </div>
                                <div class="ms-auto stat-change text-success">
                                    <small>{{activegrowth}}%</small>
                                </div>
                            </div>
                        </div>
                        <div class="stat-item mb-3">
                            <div class="d-flex align-items-center">
                                <div class="stat-icon bg-info bg-opacity-10 rounded-circle p-2 me-3">
                                    <i class="fa fa-book text-info"></i>
                                </div>
                                <div>
                                    <div class="stat-value fw-bold">{{totalcourses}}</div>
                                    <div class="stat-label text-muted small">{{#str}} totalcourses, local_customreports {{/str}}</div>
                                </div>
                            </div>
                        </div>
                        <div class="stat-item">
                            <div class="d-flex align-items-center">
                                <div class="stat-icon bg-warning bg-opacity-10 rounded-circle p-2 me-3">
                                    <i class="fa fa-graduation-cap text-warning"></i>
                                </div>
                                <div>
                                    <div class="stat-value fw-bold">{{completedcourses}}</div>
                                    <div class="stat-label text-muted small">{{#str}} completedcourses, local_customreports {{/str}}</div>
                                </div>
                                <div class="ms-auto stat-change text-success">
                                    <small>{{completionrate}}%</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white text-muted small">
                    <i class="fa fa-clock"></i>
                    {{#str}} lastupdated, local_customreports {{/str}}: <span class="last-update">{{lastupdate}}</span>
                </div>
            </div>
        </div>

        {{! Widget 2: Course Progress }}
        <div class="col-12 col-md-6 col-lg-6 widget-container" data-widget-id="course-progress" data-loaded="false">
            <div class="report-widget card h-100 shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center bg-white">
                    <h5 class="mb-0 fs-6">
                        <i class="fa fa-chart-bar text-primary"></i>
                        {{#str}} courseprogress, local_customreports {{/str}}
                    </h5>
                    <div class="widget-actions">
                        <button class="btn btn-sm btn-link p-0" data-action="refresh-widget">
                            <i class="fa fa-sync"></i>
                        </button>
                        <button class="btn btn-sm btn-link p-0" data-action="expand-widget">
                            <i class="fa fa-expand"></i>
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <canvas id="courseProgressChart" height="120"></canvas>
                </div>
                <div class="card-footer bg-white">
                    <div class="progress-legend d-flex flex-wrap gap-3 small">
                        <span class="legend-item"><span class="legend-color bg-danger"></span> 0-25%</span>
                        <span class="legend-item"><span class="legend-color bg-warning"></span> 26-50%</span>
                        <span class="legend-item"><span class="legend-color bg-orange"></span> 51-75%</span>
                        <span class="legend-item"><span class="legend-color bg-success"></span> 76-100%</span>
                    </div>
                </div>
            </div>
        </div>

        {{! Widget 3: Popular Courses }}
        <div class="col-12 col-md-6 col-lg-3 widget-container" data-widget-id="popular-courses" data-loaded="false">
            <div class="report-widget card h-100 shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center bg-white">
                    <h5 class="mb-0 fs-6">
                        <i class="fa fa-fire text-danger"></i>
                        {{#str}} popularcourses, local_customreports {{/str}}
                    </h5>
                    <button class="btn btn-sm btn-link p-0" data-action="refresh-widget">
                        <i class="fa fa-sync"></i>
                    </button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">#</th>
                                    <th>{{#str}} course, local_customreports {{/str}}</th>
                                    <th class="text-end pe-3">{{#str}} enrolled, local_customreports {{/str}}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#popularcourses}}
                                <tr>
                                    <td class="ps-3">
                                        <span class="badge {{#rank}}bg-{{rankclass}}{{/rankclass}} rounded-circle">{{rank}}</span>
                                    </td>
                                    <td>
                                        <div class="course-name small fw-medium">{{shortname}}</div>
                                        <div class="progress mt-1" style="height: 4px;">
                                            <div class="progress-bar bg-success" style="width: {{completionrate}}%"></div>
                                        </div>
                                    </td>
                                    <td class="text-end pe-3 fw-bold">{{enrolled}}</td>
                                </tr>
                                {{/popularcourses}}
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-white text-center">
                    <a href="#" class="small text-decoration-none" data-action="view-all-courses">
                        {{#str}} viewall, local_customreports {{/str}} <i class="fa fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        {{! Widget 4: Daily Activities }}
        <div class="col-12 col-lg-6 widget-container" data-widget-id="daily-activities" data-loaded="false">
            <div class="report-widget card h-100 shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center bg-white">
                    <h5 class="mb-0 fs-6">
                        <i class="fa fa-calendar-day text-primary"></i>
                        {{#str}} dailyactivities, local_customreports {{/str}}
                    </h5>
                    <div class="btn-group btn-group-sm" role="group">
                        <button class="btn btn-outline-secondary" data-period="7">7D</button>
                        <button class="btn btn-outline-secondary active" data-period="30">30D</button>
                        <button class="btn btn-outline-secondary" data-period="90">90D</button>
                    </div>
                </div>
                <div class="card-body">
                    <canvas id="dailyActivitiesChart" height="100"></canvas>
                </div>
            </div>
        </div>

        {{! Widget 5: Real-time Users }}
        <div class="col-12 col-md-6 col-lg-3 widget-container" data-widget-id="realtime-users" data-loaded="false">
            <div class="report-widget card h-100 shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center bg-white">
                    <h5 class="mb-0 fs-6">
                        <i class="fa fa-wifi text-success"></i>
                        {{#str}} realtimeusers, local_customreports {{/str}}
                    </h5>
                    <span class="badge bg-success live-indicator">
                        <i class="fa fa-circle fa-xs"></i> LIVE
                    </span>
                </div>
                <div class="card-body text-center py-5">
                    <div class="display-4 fw-bold text-success mb-2" id="online-count">{{onlinenow}}</div>
                    <div class="text-muted mb-4">{{#str}} onlinenow, local_customreports {{/str}}</div>
                    <div class="row g-2">
                        <div class="col-6">
                            <div class="bg-light rounded p-2">
                                <div class="fw-bold">{{lasthour}}</div>
                                <div class="small text-muted">{{#str}} lasthour, local_customreports {{/str}}</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="bg-light rounded p-2">
                                <div class="fw-bold">{{today}}</div>
                                <div class="small text-muted">{{#str}} today, local_customreports {{/str}}</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white text-muted small">
                    <i class="fa fa-sync fa-spin"></i>
                    {{#str}} autoupdating, local_customreports {{/str}} (30s)
                </div>
            </div>
        </div>

        {{! Widget 6: Inactive Users }}
        <div class="col-12 col-md-6 col-lg-3 widget-container" data-widget-id="inactive-users" data-loaded="false">
            <div class="report-widget card h-100 shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center bg-white">
                    <h5 class="mb-0 fs-6">
                        <i class="fa fa-user-clock text-warning"></i>
                        {{#str}} inactiveusers, local_customreports {{/str}}
                    </h5>
                    <button class="btn btn-sm btn-link p-0" data-action="refresh-widget">
                        <i class="fa fa-sync"></i>
                    </button>
                </div>
                <div class="card-body">
                    <canvas id="inactiveUsersChart" height="150"></canvas>
                </div>
                <div class="card-footer bg-white">
                    <div class="inactive-list">
                        <div class="d-flex justify-content-between mb-2 small">
                            <span><i class="fa fa-circle text-danger"></i> 7 {{#str}} days, local_customreports {{/str}}</span>
                            <span class="fw-bold">{{inactive7days}}</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 small">
                            <span><i class="fa fa-circle text-warning"></i> 30 {{#str}} days, local_customreports {{/str}}</span>
                            <span class="fw-bold">{{inactive30days}}</span>
                        </div>
                        <div class="d-flex justify-content-between small">
                            <span><i class="fa fa-circle text-muted"></i> 90 {{#str}} days, local_customreports {{/str}}</span>
                            <span class="fw-bold">{{inactive90days}}</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {{! Widget 7: Certificates Stats }}
        <div class="col-12 col-lg-6 widget-container" data-widget-id="certificates-stats" data-loaded="false">
            <div class="report-widget card h-100 shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center bg-white">
                    <h5 class="mb-0 fs-6">
                        <i class="fa fa-certificate text-warning"></i>
                        {{#str}} certificatesstats, local_customreports {{/str}}
                    </h5>
                    <button class="btn btn-sm btn-link p-0" data-action="export-widget">
                        <i class="fa fa-download"></i>
                    </button>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <canvas id="certificatesChart" height="180"></canvas>
                        </div>
                        <div class="col-md-6">
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>{{#str}} course, local_customreports {{/str}}</th>
                                            <th class="text-end">{{#str}} issued, local_customreports {{/str}}</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {{#certificates}}
                                        <tr>
                                            <td class="small">{{coursename}}</td>
                                            <td class="text-end fw-bold">{{count}}</td>
                                        </tr>
                                        {{/certificates}}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{! Loading Overlay }}
    <div class="dashboard-loading-overlay" style="display: none;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">{{#str}} loading, local_customreports {{/str}}</span>
        </div>
    </div>
</div>

{{#js}}
require(['local_customreports/dashboard'], function(Dashboard) {
    Dashboard.init({
        refreshInterval: {{refreshinterval}},
        widgets: {{widgetsconfig}}
    });
});
{{/js}}
